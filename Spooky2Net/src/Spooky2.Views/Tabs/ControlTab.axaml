<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Spooky2.Views.Tabs.ControlTab">

    <Grid ColumnDefinitions="160,*,300" Margin="4,2">

        <!-- ═══ LEFT: Controls ═══ -->
        <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,4,0">
            <!-- Generator selector -->
            <ComboBox ItemsSource="{Binding AvailableGenerators}"
                      SelectedItem="{Binding SelectedGenerator}"
                      HorizontalAlignment="Stretch"
                      FontSize="10" Height="28"
                      PlaceholderText="Select generator..." />

            <!-- Action buttons -->
            <Button Content="▶ Start" Command="{Binding StartCommand}"
                    HorizontalAlignment="Stretch" Height="28" FontSize="11"
                    HorizontalContentAlignment="Center" Background="#D0F0D0"/>
            <Button Content="⏹ Stop" Command="{Binding StopCommand}"
                    HorizontalAlignment="Stretch" Height="28" FontSize="11"
                    HorizontalContentAlignment="Center" Background="#FFD0D0"/>
            <Button Content="⏸ Pause" Command="{Binding PauseCommand}"
                    HorizontalAlignment="Stretch" Height="24" FontSize="10"
                    HorizontalContentAlignment="Center"/>
            <Button Content="⏏ Hold" Command="{Binding HoldCommand}"
                    HorizontalAlignment="Stretch" Height="24" FontSize="10"
                    HorizontalContentAlignment="Center"/>

            <Separator Margin="0,4"/>

            <Button Content="🔍 Scan" Command="{Binding ScanCommand}"
                    HorizontalAlignment="Stretch" Height="28" FontSize="11"
                    HorizontalContentAlignment="Center" Background="#D0E8FF"/>
            <Button Content="⚡ Hunt and Kill" Command="{Binding HuntAndKillCommand}"
                    HorizontalAlignment="Stretch" Height="32" FontSize="12"
                    FontWeight="Bold"
                    HorizontalContentAlignment="Center" Background="#FFE060"/>

            <Separator Margin="0,4"/>

            <!-- Scan progress -->
            <ProgressBar IsIndeterminate="{Binding IsScanning}"
                         IsVisible="{Binding IsScanning}"
                         Height="6"/>
            <TextBlock Text="{Binding ScanStatusText}"
                       FontSize="9" TextWrapping="Wrap"
                       MaxHeight="32"/>

            <!-- Generator status -->
            <Border Background="#2D2D2D" CornerRadius="3" Padding="6,4" Margin="0,4,0,0">
                <StackPanel Spacing="1">
                    <TextBlock Text="{Binding GeneratorStatusText}"
                               Foreground="LimeGreen" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="{Binding GeneratorTitle}"
                               Foreground="Gray" FontSize="9" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Separator Margin="0,4"/>

            <!-- Quick actions -->
            <WrapPanel Orientation="Horizontal">
                <Button Content="Erase" Command="{Binding EraseFrequenciesCommand}"
                        Width="50" Height="22" FontSize="9" Margin="0,0,2,2"/>
                <Button Content="Reset" Command="{Binding ResetGeneratorCommand}"
                        Width="50" Height="22" FontSize="9" Margin="0,0,2,2"/>
                <Button Content="Copy" Command="{Binding CopyFrequenciesCommand}"
                        Width="46" Height="22" FontSize="9" Margin="0,0,2,2"/>
            </WrapPanel>

            <!-- Timing -->
            <StackPanel Spacing="1" Margin="0,4,0,0">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Dwell:" FontSize="9" Foreground="Gray"/>
                    <TextBlock Text="{Binding DwellValue}" FontSize="9" FontWeight="Bold"/>
                    <TextBlock Text="s" FontSize="9" Foreground="Gray"/>
                </StackPanel>
                <TextBlock Text="{Binding EstimatedTotalRunTime, StringFormat='ETA: {0}'}"
                           FontSize="9" Foreground="Gray"/>
                <TextBlock Text="{Binding CurrentPresetDuration, StringFormat='Elapsed: {0}'}"
                           FontSize="9" Foreground="Gray"/>
            </StackPanel>
        </StackPanel>

        <!-- ═══ CENTER: Frequencies ═══ -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" Margin="0,0,4,0">
            <!-- Title bar -->
            <Border Grid.Row="0" Background="#000060" Padding="6,3" CornerRadius="3,3,0,0">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding GeneratorTitle}" Foreground="White"
                               FontWeight="Bold" FontSize="11" FontFamily="Courier New"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding TotalStatus}"
                               Foreground="#80FFFFFF" FontSize="10"/>
                </Grid>
            </Border>

            <!-- Frequency list -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding FrequencyItems}"
                     SelectedItem="{Binding SelectedFrequency}"
                     SelectedIndex="{Binding SelectedFrequencyIndex}"
                     FontFamily="Courier New" FontSize="11"
                     BorderThickness="1" BorderBrush="Gray"/>

            <!-- Progress -->
            <ProgressBar Grid.Row="2"
                         Value="{Binding ProgressValue}"
                         Maximum="{Binding ProgressMaximum}"
                         Height="8" Margin="0,2,0,0"/>
        </Grid>

        <!-- ═══ RIGHT: Hits + Output ═══ -->
        <Grid Grid.Column="2" RowDefinitions="*,Auto">

            <!-- Biofeedback Hits -->
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="3"
                    Margin="0,0,0,4">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Background="#000060" Padding="4,2"
                            CornerRadius="3,3,0,0">
                        <TextBlock Text="Biofeedback Hits" Foreground="White"
                                   FontSize="10" FontWeight="Bold"/>
                    </Border>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding BiofeedbackHits}"
                             FontSize="10" FontFamily="Courier New"/>
                </Grid>
            </Border>

            <!-- Generator Output (compact) -->
            <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1"
                    Padding="4" CornerRadius="3">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="60,*,*">
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="Output"
                               FontWeight="Bold" FontSize="10" Margin="0,0,0,2"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="" FontSize="9"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Out 1" FontWeight="Bold"
                               FontSize="9" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Out 2" FontWeight="Bold"
                               FontSize="9" HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Freq" FontSize="9"/>
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               Text="{Binding Output1Frequency, StringFormat='{}{0:N2} Hz'}"
                               FontSize="9" FontFamily="Courier New" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="2"
                               Text="{Binding Output2Frequency, StringFormat='{}{0:N2} Hz'}"
                               FontSize="9" FontFamily="Courier New" HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Wave" FontSize="9"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Output1WaveformDisplay}"
                               FontSize="9" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding Output2WaveformDisplay}"
                               FontSize="9" HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Amp" FontSize="9"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Output1AmplitudeDisplay}"
                               FontSize="9" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding Output2AmplitudeDisplay}"
                               FontSize="9" HorizontalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
