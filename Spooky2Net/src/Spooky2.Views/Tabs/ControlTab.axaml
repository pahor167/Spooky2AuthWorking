<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Spooky2.Views.Tabs.ControlTab"
             Background="#E8E8E8">

    <!-- Main 3-column, 2-row layout -->
    <Grid RowDefinitions="*,Auto"
          ColumnDefinitions="220,*,380"
          Margin="4">

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- LEFT COLUMN: Generator Control                          -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.Column="0"
                BorderBrush="Gray" BorderThickness="1" Padding="4" Margin="0,0,4,4"
                Background="White">
            <StackPanel Spacing="4">
                <TextBlock Text="Generators" FontWeight="Bold" FontSize="11"
                           Background="#D4D0C8" Padding="2"/>

                <CheckBox Content="Overwrite Generator"
                          IsChecked="{Binding OverwriteGenerator}"
                          FontSize="11"/>

                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Text="{Binding GeneratorSaveName}"
                             FontSize="11" Height="22"/>
                    <Button Grid.Column="1" Content="Save"
                            Command="{Binding SaveGeneratorCommand}"
                            Width="40" Height="22" FontSize="10" Margin="2,0,0,0"/>
                </Grid>

                <!-- Generator number/percent display -->
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding GeneratorNumber1}" Width="28" Height="22"
                             FontSize="11" HorizontalContentAlignment="Center"/>
                    <TextBlock Text="{Binding GeneratorPercent1, StringFormat='{}{0}%'}"
                               VerticalAlignment="Center" FontSize="11"/>
                    <TextBox Text="{Binding GeneratorNumber2}" Width="28" Height="22"
                             FontSize="11" HorizontalContentAlignment="Center"/>
                    <TextBlock Text="{Binding GeneratorPercent2, StringFormat='{}{0}%'}"
                               VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>

                <!-- Control buttons -->
                <Button Content="Start" Command="{Binding StartCommand}"
                        HorizontalAlignment="Stretch" Height="26" FontSize="11"
                        HorizontalContentAlignment="Center"/>
                <Button Content="Scan" Command="{Binding ScanCommand}"
                        HorizontalAlignment="Stretch" Height="26" FontSize="11"
                        HorizontalContentAlignment="Center"/>
                <Button Content="Pause" Command="{Binding PauseCommand}"
                        HorizontalAlignment="Stretch" Height="26" FontSize="11"
                        HorizontalContentAlignment="Center"/>
                <Button Content="Hold" Command="{Binding HoldCommand}"
                        HorizontalAlignment="Stretch" Height="26" FontSize="11"
                        HorizontalContentAlignment="Center"/>
                <Button Content="Amplitude Wobble" Command="{Binding AmplitudeWobbleCommand}"
                        HorizontalAlignment="Stretch" Height="26" FontSize="11"
                        HorizontalContentAlignment="Center"/>
                <Button Content="Frequency Wobble" Command="{Binding FrequencyWobbleCommand}"
                        HorizontalAlignment="Stretch" Height="26" FontSize="11"
                        HorizontalContentAlignment="Center"/>
                <Button Content="Stop" Command="{Binding StopCommand}"
                        HorizontalAlignment="Stretch" Height="26" FontSize="11"
                        HorizontalContentAlignment="Center" Background="#FFE0E0"/>
            </StackPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- CENTER COLUMN: Frequency Display & Status               -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Grid.Column="1"
              RowDefinitions="Auto,*,Auto,Auto,Auto"
              Margin="0,0,4,4">

            <!-- Generator title bar -->
            <Border Grid.Row="0" Background="#000080" Padding="4,2">
                <TextBlock Text="{Binding GeneratorTitle}"
                           Foreground="White" FontWeight="Bold" FontSize="12"
                           FontFamily="Courier New"/>
            </Border>

            <!-- Frequency list -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding FrequencyItems}"
                     SelectedItem="{Binding SelectedFrequency}"
                     SelectedIndex="{Binding SelectedFrequencyIndex}"
                     Background="White"
                     FontFamily="Courier New" FontSize="12"
                     BorderBrush="Gray" BorderThickness="1"/>

            <!-- Progress bar -->
            <ProgressBar Grid.Row="2"
                         Value="{Binding ProgressValue}"
                         Maximum="{Binding ProgressMaximum}"
                         Height="16" Margin="0,2"/>

            <!-- Status row -->
            <Border Grid.Row="3" Background="#D4D0C8" Padding="4,2" Margin="0,2">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <TextBlock Text="Dwell:" FontSize="11"/>
                        <TextBlock Text="{Binding DwellValue}" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <TextBlock Text="Step:" FontSize="11"/>
                        <TextBlock Text="{Binding StepValue}" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <TextBlock Text="Preset:" FontSize="11"/>
                        <TextBlock Text="{Binding PresetValue}" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <TextBlock Text="Age Factor:" FontSize="11"/>
                        <TextBlock Text="{Binding AgeFactor}" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <TextBlock Text="Total:" FontSize="11"/>
                        <TextBlock Text="{Binding TotalStatus}" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Frequency Adjustment -->
            <Grid Grid.Row="4" ColumnDefinitions="*,80,Auto" Margin="0,2,0,0">
                <Slider Grid.Column="0"
                        Value="{Binding FrequencyAdjustSlider}"
                        Minimum="-100" Maximum="100"
                        VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                         Text="{Binding FrequencyAdjustHz}"
                         FontSize="11" Height="22"
                         HorizontalContentAlignment="Center" Margin="4,0"/>
                <Button Grid.Column="2" Content="Hz"
                        Command="{Binding RefreshFrequencyCommand}"
                        Width="30" Height="22" FontSize="10"/>
            </Grid>
        </Grid>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- RIGHT COLUMN: Run Time, Biofeedback, Generator Output   -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Grid.Column="2"
              RowDefinitions="Auto,*,Auto,Auto"
              Margin="0,0,0,4">

            <!-- Run Time Display -->
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1"
                    Padding="4" Background="White" Margin="0,0,0,4">
                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Estimated Total Run Time:"
                               FontSize="11" Margin="0,0,8,2"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EstimatedTotalRunTime}"
                               FontSize="11" FontFamily="Courier New" FontWeight="Bold"
                               HorizontalAlignment="Right"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Current Preset Duration:"
                               FontSize="11" Margin="0,0,8,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentPresetDuration}"
                               FontSize="11" FontFamily="Courier New" FontWeight="Bold"
                               HorizontalAlignment="Right"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Current Chain Duration:"
                               FontSize="11" Margin="0,0,8,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentChainDuration}"
                               FontSize="11" FontFamily="Courier New" FontWeight="Bold"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <!-- Biofeedback Hits -->
            <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1"
                    Margin="0,0,0,4">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Background="#000080" Padding="4,2">
                        <TextBlock Text="Biofeedback Hits" Foreground="White"
                                   FontSize="11" FontWeight="Bold"/>
                    </Border>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding BiofeedbackHits}"
                             SelectedItem="{Binding SelectedBiofeedbackHit}"
                             Background="White" FontSize="11"/>
                </Grid>
            </Border>

            <!-- Reverse Lookup -->
            <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1"
                    Padding="4" Background="White" Margin="0,0,0,4">
                <StackPanel Spacing="2">
                    <TextBlock Text="Reverse Lookup" FontWeight="Bold" FontSize="11"
                               Background="#D4D0C8" Padding="2" Margin="-4,-4,-4,4"/>

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <CheckBox Grid.Column="0" Content="Include Harmonics"
                                  IsChecked="{Binding IncludeHarmonics}" FontSize="11"/>
                        <Button Grid.Column="2" Content="Go"
                                Command="{Binding ReverseLookupGoCommand}"
                                Width="40" Height="22" FontSize="10"/>
                    </Grid>

                    <CheckBox Content="Include Sub-Harmonics"
                              IsChecked="{Binding IncludeSubHarmonics}" FontSize="11"/>

                    <Grid ColumnDefinitions="Auto,60,Auto,60,Auto,60" Margin="0,2,0,0">
                        <TextBlock Grid.Column="0" Text="Octave:" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding OctaveValues}"
                                  SelectedItem="{Binding OctaveValue}"
                                  Height="24" FontSize="11"/>
                        <TextBlock Grid.Column="2" Text="Tolerance:" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,4,0"/>
                        <TextBox Grid.Column="3" Text="{Binding TolerancePercent}"
                                 Height="22" FontSize="11" HorizontalContentAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="% Include:" FontSize="11"
                                   VerticalAlignment="Center" Margin="4,0,4,0"/>
                        <TextBox Grid.Column="5" Text="{Binding IncludeHz}"
                                 Height="22" FontSize="11" HorizontalContentAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Generator Output -->
            <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="1"
                    Padding="4" Background="White">
                <StackPanel Spacing="2">
                    <TextBlock Text="Generator Output" FontWeight="Bold" FontSize="11"
                               Background="#D4D0C8" Padding="2" Margin="-4,-4,-4,4"/>

                    <!-- Output table header -->
                    <Grid ColumnDefinitions="80,90,70,90">
                        <TextBlock Grid.Column="0" Text="Label" FontWeight="Bold" FontSize="10"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Out 1" FontWeight="Bold" FontSize="10"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Sync" FontWeight="Bold" FontSize="10"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="Out 2" FontWeight="Bold" FontSize="10"
                                   HorizontalAlignment="Center"/>
                    </Grid>

                    <Separator Margin="0,2"/>

                    <!-- Frequency row -->
                    <Grid ColumnDefinitions="80,90,70,90">
                        <TextBlock Grid.Column="0" Text="Frequency" FontSize="10" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Output1Frequency, StringFormat='{}{0:F3}'}"
                                   FontSize="9" FontFamily="Courier New" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="{Binding Output2Frequency, StringFormat='{}{0:F3}'}"
                                   FontSize="9" FontFamily="Courier New" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Waveform row -->
                    <Grid ColumnDefinitions="80,90,70,90">
                        <TextBlock Grid.Column="0" Text="Waveform" FontSize="10" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Output1WaveformDisplay}"
                                   FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding SyncWaveformDisplay}"
                                   FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="{Binding Output2WaveformDisplay}"
                                   FontSize="9" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Duty Cycle row -->
                    <Grid ColumnDefinitions="80,90,70,90">
                        <TextBlock Grid.Column="0" Text="Duty Cycle" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding Output1DutyCycle}"
                                   FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="" FontSize="9"/>
                        <TextBlock Grid.Column="3" Text="{Binding Output2DutyCycle}"
                                   FontSize="9" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Amplitude row -->
                    <Grid ColumnDefinitions="80,90,70,90">
                        <TextBlock Grid.Column="0" Text="Amplitude" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding Output1AmplitudeDisplay}"
                                   FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="" FontSize="9"/>
                        <TextBlock Grid.Column="3" Text="{Binding Output2AmplitudeDisplay}"
                                   FontSize="9" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Offset row -->
                    <Grid ColumnDefinitions="80,90,70,90">
                        <TextBlock Grid.Column="0" Text="Offset" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding Output1Offset}"
                                   FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="" FontSize="9"/>
                        <TextBlock Grid.Column="3" Text="{Binding Output2Offset}"
                                   FontSize="9" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Phase row -->
                    <Grid ColumnDefinitions="80,90,70,90">
                        <TextBlock Grid.Column="0" Text="Phase" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding Output1PhaseDisplay}"
                                   FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="" FontSize="9"/>
                        <TextBlock Grid.Column="3" Text="{Binding Output2PhaseDisplay}"
                                   FontSize="9" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Angle row -->
                    <Grid ColumnDefinitions="80,90,70,90">
                        <TextBlock Grid.Column="0" Text="Angle" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding Output1Angle, StringFormat='{}{0:F2}'}"
                                   FontSize="9" FontFamily="Courier New" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="" FontSize="9"/>
                        <TextBlock Grid.Column="3" Text="{Binding Output2Angle, StringFormat='{}{0:F2}'}"
                                   FontSize="9" FontFamily="Courier New" HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- Current row -->
                    <Grid ColumnDefinitions="80,90,70,90">
                        <TextBlock Grid.Column="0" Text="Current" FontSize="10"/>
                        <TextBlock Grid.Column="1" Text="{Binding Output1Current, StringFormat='{}{0:F2}'}"
                                   FontSize="9" FontFamily="Courier New" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="" FontSize="9"/>
                        <TextBlock Grid.Column="3" Text="{Binding Output2Current, StringFormat='{}{0:F2}'}"
                                   FontSize="9" FontFamily="Courier New" HorizontalAlignment="Center"/>
                    </Grid>

                    <Separator Margin="0,4"/>

                    <!-- Special Functions -->
                    <TextBlock Text="Special Functions" FontWeight="Bold" FontSize="11"
                               Margin="0,0,0,2"/>
                    <WrapPanel Orientation="Horizontal">
                        <Button Content="Load GX" Command="{Binding LoadGxCommand}"
                                Width="65" Height="24" FontSize="10" Margin="0,0,2,2"/>
                        <Button Content="Paste" Command="{Binding PasteFrequenciesCommand}"
                                Width="50" Height="24" FontSize="10" Margin="0,0,2,2"/>
                        <Button Content="Copy" Command="{Binding CopyFrequenciesCommand}"
                                Width="50" Height="24" FontSize="10" Margin="0,0,2,2"/>
                        <Button Content="Erase" Command="{Binding EraseFrequenciesCommand}"
                                Width="50" Height="24" FontSize="10" Margin="0,0,2,2"/>
                        <Button Content="Reset" Command="{Binding ResetGeneratorCommand}"
                                Width="50" Height="24" FontSize="10" Margin="0,0,2,2"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- BOTTOM ROW: Biofeedback Scan | Detect | Calculate       -->
        <!-- ════════════════════════════════════════════════════════ -->

        <!-- Bottom Left: Biofeedback Scan -->
        <Border Grid.Row="1" Grid.Column="0"
                BorderBrush="Gray" BorderThickness="1"
                Padding="4" Background="White" Margin="0,0,4,0">
            <StackPanel Spacing="2">
                <TextBlock Text="Biofeedback Scan" FontWeight="Bold" FontSize="11"
                           Background="#D4D0C8" Padding="2" Margin="-4,-4,-4,4"/>

                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                      Margin="0,0,0,0">

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Log Name:" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,4,2"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ScanLogName}"
                             Height="20" FontSize="10" Margin="0,0,0,2"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Start Freq:" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,4,2"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="2" Margin="0,0,0,2">
                        <TextBox Text="{Binding ScanStartFrequency}" Width="80" Height="20" FontSize="10"
                                 HorizontalContentAlignment="Right"/>
                        <TextBlock Text="Hz" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Finish Freq:" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,4,2"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="2" Margin="0,0,0,2">
                        <TextBox Text="{Binding ScanFinishFrequency}" Width="80" Height="20" FontSize="10"
                                 HorizontalContentAlignment="Right"/>
                        <TextBlock Text="Hz" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Init Step:" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,4,2"/>
                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="2" Margin="0,0,0,2">
                        <TextBox Text="{Binding ScanInitialStepSize}" Width="60" Height="20" FontSize="10"
                                 HorizontalContentAlignment="Right"/>
                        <RadioButton Content="Hz" IsChecked="{Binding ScanStepSizeHz}"
                                     GroupName="StepSizeUnit" FontSize="10"/>
                        <RadioButton Content="%" IsChecked="{Binding ScanStepSizePercent}"
                                     GroupName="StepSizeUnit" FontSize="10"/>
                    </StackPanel>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Max Hits:" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,4,2"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ScanMaxHits}"
                             Width="40" Height="20" FontSize="10" HorizontalAlignment="Left"
                             HorizontalContentAlignment="Center" Margin="0,0,0,2"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Samples/Step:" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,4,2"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding ScanSamplesPerStep}"
                             Width="40" Height="20" FontSize="10" HorizontalAlignment="Left"
                             HorizontalContentAlignment="Center" Margin="0,0,0,2"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Loops:" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,4,2"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding ScanLoops}"
                             Width="40" Height="20" FontSize="10" HorizontalAlignment="Left"
                             HorizontalContentAlignment="Center" Margin="0,0,0,2"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Start Delay:" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,4,2"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding ScanStartDelay}"
                             Width="40" Height="20" FontSize="10" HorizontalAlignment="Left"
                             HorizontalContentAlignment="Center" Margin="0,0,0,2"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Min Read Delay:" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,4,2"/>
                    <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" Spacing="2" Margin="0,0,0,2">
                        <TextBox Text="{Binding ScanMinReadDelay}" Width="40" Height="20" FontSize="10"
                                 HorizontalContentAlignment="Center"/>
                        <TextBlock Text="s" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Threshold:" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,4,2"/>
                    <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding ScanThreshold}"
                             Width="40" Height="20" FontSize="10" HorizontalAlignment="Left"
                             HorizontalContentAlignment="Center" Margin="0,0,0,2"/>

                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Est. Duration:" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding ScanEstDuration}"
                               FontSize="10" FontFamily="Courier New" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Bottom Center: Detect & After Scan -->
        <Border Grid.Row="1" Grid.Column="1"
                BorderBrush="Gray" BorderThickness="1"
                Padding="4" Background="White" Margin="0,0,4,0">
            <StackPanel Spacing="4">

                <!-- Detect -->
                <TextBlock Text="Detect" FontWeight="Bold" FontSize="11"
                           Background="#D4D0C8" Padding="2" Margin="-4,-4,-4,4"/>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <RadioButton Content="Max" IsChecked="{Binding DetectMax}"
                                 GroupName="DetectMode" FontSize="10"/>
                    <RadioButton Content="Min" IsChecked="{Binding DetectMin}"
                                 GroupName="DetectMode" FontSize="10"/>
                    <RadioButton Content="Change" IsChecked="{Binding DetectChange}"
                                 GroupName="DetectMode" FontSize="10"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <RadioButton Content="Angle" IsChecked="{Binding DetectAngle}"
                                 GroupName="DetectType" FontSize="10"/>
                    <RadioButton Content="Current" IsChecked="{Binding DetectCurrent}"
                                 GroupName="DetectType" FontSize="10"/>
                    <RadioButton Content="BPM" IsChecked="{Binding DetectBpm}"
                                 GroupName="DetectType" FontSize="10"/>
                    <RadioButton Content="HRV" IsChecked="{Binding DetectHrv}"
                                 GroupName="DetectType" FontSize="10"/>
                </StackPanel>

                <RadioButton Content="Angle+Current" IsChecked="{Binding DetectAnglePlusCurrent}"
                             GroupName="DetectType" FontSize="10"/>

                <Separator Margin="0,2"/>

                <!-- RA Window -->
                <TextBlock Text="RA Window" FontWeight="Bold" FontSize="11" Margin="0,0,0,2"/>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBox Text="{Binding RaWindowSize}" Width="40" Height="20"
                             FontSize="10" HorizontalContentAlignment="Center"/>
                    <TextBlock Text="n" FontSize="10" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding RaWindowN}" Width="40" Height="20"
                             FontSize="10" HorizontalContentAlignment="Center"/>
                    <TextBox Text="{Binding RaWindowOffset}" Width="40" Height="20"
                             FontSize="10" HorizontalContentAlignment="Center"/>
                    <CheckBox Content="Retentive" IsChecked="{Binding RaRetentive}"
                              FontSize="10"/>
                </StackPanel>

                <Separator Margin="0,2"/>

                <!-- After Scan -->
                <TextBlock Text="After Scan" FontWeight="Bold" FontSize="11" Margin="0,0,0,2"/>
                <CheckBox Content="Run Hits" IsChecked="{Binding AfterScanRunHits}"
                          FontSize="10"/>
                <CheckBox Content="Continue Refining Hits"
                          IsChecked="{Binding AfterScanContinueRefining}" FontSize="10"/>

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Run on Gen:" FontSize="10" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding AfterScanRunOnGen}" Width="30" Height="20"
                             FontSize="10" HorizontalContentAlignment="Center"/>
                    <TextBlock Text="Run Cycles:" FontSize="10" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding AfterScanRunCycles}" Width="30" Height="20"
                             FontSize="10" HorizontalContentAlignment="Center"/>
                    <TextBox Text="{Binding AfterScanRunCycles2}" Width="30" Height="20"
                             FontSize="10" HorizontalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Bottom Right: Calculate Using & Graph -->
        <Border Grid.Row="1" Grid.Column="2"
                BorderBrush="Gray" BorderThickness="1"
                Padding="4" Background="White" Margin="0,0,0,0">
            <StackPanel Spacing="4">

                <!-- Calculate Using -->
                <TextBlock Text="Calculate Using" FontWeight="Bold" FontSize="11"
                           Background="#D4D0C8" Padding="2" Margin="-4,-4,-4,4"/>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <RadioButton Content="Running Average" IsChecked="{Binding CalcRunningAverage}"
                                 GroupName="CalcMode" FontSize="10"/>
                    <RadioButton Content="Peak" IsChecked="{Binding CalcPeak}"
                                 GroupName="CalcMode" FontSize="10"/>
                    <RadioButton Content="Single Scan" IsChecked="{Binding CalcSingleScan}"
                                 GroupName="CalcMode" FontSize="10"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <CheckBox Content="Grade Program" IsChecked="{Binding CalcGradeProgram}"
                              FontSize="10"/>
                    <CheckBox Content="Prevent Duplicates" IsChecked="{Binding CalcPreventDuplicates}"
                              FontSize="10"/>
                </StackPanel>

                <Separator Margin="0,2"/>

                <!-- BPM/HRV/VI display -->
                <Grid ColumnDefinitions="Auto,60,Auto,60,Auto,60,Auto,60">
                    <TextBlock Grid.Column="0" Text="BPM:" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding DisplayBpm, StringFormat='{}{0:F1}'}"
                               FontSize="10" FontFamily="Courier New" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="HRV:" FontSize="10"
                               VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBlock Grid.Column="3" Text="{Binding DisplayHrv, StringFormat='{}{0:F1}'}"
                               FontSize="10" FontFamily="Courier New" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="Angle:" FontSize="10"
                               VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBlock Grid.Column="5" Text="{Binding DisplayViAngle, StringFormat='{}{0:F2}'}"
                               FontSize="10" FontFamily="Courier New" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="6" Text="Current:" FontSize="10"
                               VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBlock Grid.Column="7" Text="{Binding DisplayCurrent, StringFormat='{}{0:F2}'}"
                               FontSize="10" FontFamily="Courier New" VerticalAlignment="Center"/>
                </Grid>

                <Separator Margin="0,2"/>

                <!-- Biofeedback Graph placeholder -->
                <Border Background="#FFE8E0E8" BorderBrush="Gray" BorderThickness="1"
                        MinHeight="120">
                    <TextBlock Text="Biofeedback Graph" FontSize="10"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="Gray"/>
                </Border>

                <!-- Analyze buttons -->
                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center"
                            Margin="0,4,0,0">
                    <Button Content="Analyze" Command="{Binding AnalyzeCommand}"
                            Width="70" Height="24" FontSize="10"/>
                    <Button Content="Analyze+" Command="{Binding AnalyzePlusCommand}"
                            Width="70" Height="24" FontSize="10"/>
                    <Button Content="Baseline" Command="{Binding BaselineCommand}"
                            Width="70" Height="24" FontSize="10"/>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
