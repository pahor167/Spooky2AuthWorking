<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Spooky2.Views.Dialogs.MessageView"
        Title="Spooky2"
        Width="400" Height="250"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        FontFamily="Arial"
        FontSize="13">

    <Grid ColumnDefinitions="Auto,*" RowDefinitions="*,Auto" Margin="8">

        <!-- Left: Logo area -->
        <Border Grid.Row="0" Grid.Column="0" Width="120" Height="120" Background="#E0E0E0"
                CornerRadius="4" VerticalAlignment="Center" Margin="0,0,16,0">
            <TextBlock Text="Spooky2" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="Gray" FontWeight="Bold" />
        </Border>

        <!-- Right: Message text -->
        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MessageText, FallbackValue=-}"
                   TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center"
                   TextAlignment="Center" FontSize="14" />

        <!-- Bottom: OK button -->
        <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Content="OK" Command="{Binding OkCommand}"
                HorizontalAlignment="Center" Width="100" Margin="0,12,0,0"
                ToolTip.Tip="Close this window" />
    </Grid>
</Window>
