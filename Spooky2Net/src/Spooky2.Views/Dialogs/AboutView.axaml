<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Spooky2.Views.Dialogs.AboutView"
        Title="About Spooky2"
        Width="400" Height="300"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        FontFamily="Arial"
        FontSize="13">

    <Grid ColumnDefinitions="Auto,*" RowDefinitions="*,Auto" Margin="12">

        <!-- Left: Logo images -->
        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="8" Margin="0,0,16,0" VerticalAlignment="Top">
            <Border Width="120" Height="120" Background="#E0E0E0" CornerRadius="4">
                <TextBlock Text="Spooky2" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="Gray" FontWeight="Bold" />
            </Border>
            <Border Width="120" Height="80" Background="#E0F0E0" CornerRadius="4"
                    ToolTip.Tip="New Zealand. Unpolluted paradise">
                <TextBlock Text="NZ" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="Gray" />
            </Border>
        </StackPanel>

        <!-- Right: About text (read-only, scrollable) -->
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding AboutText}"
                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                 BorderThickness="0" Background="Transparent" FontSize="13" />

        <!-- Bottom: OK button -->
        <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Content="OK" Command="{Binding CloseCommand}"
                HorizontalAlignment="Center" Width="100" Margin="0,12,0,0" />
    </Grid>
</Window>
