<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Spooky2.Views.Dialogs.DatabaseHelpView"
        Title="Database Help"
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner"
        FontFamily="Arial"
        FontSize="13">

    <Grid Margin="8" RowDefinitions="*,Auto">

        <!-- Row 0: Help text content area (read-only, multiline, scrollable) -->
        <TextBox Grid.Row="0" Text="{Binding HelpText}" IsReadOnly="True"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 BorderThickness="0" Background="Transparent"
                 Margin="0,0,0,8" />

        <!-- Row 1: Close button -->
        <Button Grid.Row="1" Content="Close" Command="{Binding CloseCommand}"
                HorizontalAlignment="Center" Width="100" />
    </Grid>
</Window>
