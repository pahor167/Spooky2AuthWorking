<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Spooky2.Views.Controls.GeneratorPanel">

    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8,4"
            Margin="0,1">
        <Grid ColumnDefinitions="60,100,Auto,*,120,120">

            <!-- Generator ID -->
            <TextBlock Grid.Column="0"
                       Text="{Binding GeneratorId, StringFormat='Gen {0}'}"
                       FontWeight="Bold"
                       VerticalAlignment="Center" />

            <!-- Port / Status -->
            <StackPanel Grid.Column="1"
                        Orientation="Vertical"
                        VerticalAlignment="Center"
                        Margin="8,0">
                <TextBlock Text="{Binding Port}"
                           FontSize="9" />
                <TextBlock Text="{Binding Status}"
                           FontSize="9"
                           FontWeight="Bold" />
            </StackPanel>

            <!-- Control buttons -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">
                <Button Content="Start"
                        Command="{Binding StartCommand}"
                        Width="55" Height="28"
                        FontSize="10" />
                <Button Content="Stop"
                        Command="{Binding StopCommand}"
                        Width="55" Height="28"
                        FontSize="10" />
                <Button Content="Pause"
                        Command="{Binding PauseCommand}"
                        Width="55" Height="28"
                        FontSize="10" />
                <Button Content="Hold"
                        Command="{Binding HoldCommand}"
                        Width="55" Height="28"
                        FontSize="10" />
            </StackPanel>

            <!-- Current frequency + program -->
            <StackPanel Grid.Column="3"
                        Orientation="Vertical"
                        VerticalAlignment="Center"
                        Margin="12,0">
                <TextBlock Text="{Binding CurrentFrequency, StringFormat='{}{0:F2} Hz'}"
                           FontFamily="Courier New"
                           FontSize="10" />
                <TextBlock Text="{Binding CurrentProgram}"
                           FontSize="9"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!-- Elapsed time -->
            <TextBlock Grid.Column="5"
                       Text="{Binding ElapsedTime}"
                       FontFamily="Courier New"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right" />
        </Grid>
    </Border>
</UserControl>
