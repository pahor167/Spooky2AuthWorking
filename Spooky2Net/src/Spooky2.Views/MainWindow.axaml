<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tabs="clr-namespace:Spooky2.Views.Tabs"
        xmlns:controls="clr-namespace:Spooky2.Views.Controls"
        x:Class="Spooky2.Views.MainWindow"
        Title="FreqGen"
        Icon="avares://Spooky2.Views/Assets/icon.png"
        WindowState="Maximized"
        FontFamily="Arial"
        FontSize="11.25"
        WindowStartupLocation="CenterOwner">

    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="File">
                <NativeMenu>
                    <NativeMenuItem Header="Save" Command="{Binding SaveCommand}" />
                    <NativeMenuItemSeparator />
                    <NativeMenuItem Header="Exit" Command="{Binding ExitApplicationCommand}" />
                </NativeMenu>
            </NativeMenuItem>
            <NativeMenuItem Header="System">
                <NativeMenu>
                    <NativeMenuItem Header="Identify Generators" Command="{Binding IdentifyGeneratorsCommand}" />
                    <NativeMenuItem Header="Identify USB Devices" Command="{Binding IdentifyUsbDevicesCommand}" />
                    <NativeMenuItem Header="Rescan Devices" Command="{Binding RescanDevicesCommand}" />
                    <NativeMenuItemSeparator />
                    <NativeMenuItem Header="Install XM Drivers" Command="{Binding InstallXmDriversCommand}" />
                    <NativeMenuItem Header="Install GeneratorX Drivers" Command="{Binding InstallGeneratorXDriversCommand}" />
                    <NativeMenuItem Header="Install Chain Editor" Command="{Binding InstallChainEditorCommand}" />
                    <NativeMenuItemSeparator />
                    <NativeMenuItem Header="Clean Registry" Command="{Binding CleanRegistryCommand}" />
                    <NativeMenuItem Header="Update GX Pro Firmware" Command="{Binding UpdateGxProFirmwareCommand}" />
                    <NativeMenuItem Header="GX Pro Firmware Instructions" Command="{Binding GxProFirmwareInstructionsCommand}" />
                    <NativeMenuItem Header="GX Screen ON" Command="{Binding GxScreenOnCommand}" />
                    <NativeMenuItem Header="GX Screen OFF" Command="{Binding GxScreenOffCommand}" />
                </NativeMenu>
            </NativeMenuItem>
            <NativeMenuItem Header="Generators">
                <NativeMenu>
                    <NativeMenuItem Header="Global Start" Command="{Binding GlobalStartCommand}" />
                    <NativeMenuItem Header="Global Stop" Command="{Binding GlobalStopCommand}" />
                    <NativeMenuItem Header="Global Pause" Command="{Binding GlobalPauseCommand}" />
                    <NativeMenuItem Header="Global Unpause" Command="{Binding GlobalUnpauseCommand}" />
                    <NativeMenuItem Header="Global Hold" Command="{Binding GlobalHoldCommand}" />
                    <NativeMenuItem Header="Global Resume" Command="{Binding GlobalResumeCommand}" />
                    <NativeMenuItemSeparator />
                    <NativeMenuItem Header="Global Erase" Command="{Binding GlobalEraseCommand}" />
                </NativeMenu>
            </NativeMenuItem>
            <NativeMenuItem Header="Database">
                <NativeMenu>
                    <NativeMenuItem Header="Refresh Database" Command="{Binding RefreshDatabaseCommand}" />
                    <NativeMenuItem Header="Refresh Waveforms" Command="{Binding RefreshWaveformsCommand}" />
                    <NativeMenuItem Header="Refresh Freq Wobbles" Command="{Binding RefreshFreqWobblesCommand}" />
                    <NativeMenuItemSeparator />
                    <NativeMenuItem Header="Write Database Text" Command="{Binding WriteDatabaseTextCommand}" />
                    <NativeMenuItem Header="Extract Preset Frequencies" Command="{Binding ExtractPresetFrequenciesCommand}" />
                    <NativeMenuItemSeparator />
                    <NativeMenuItem Header="Edit Custom Database 1" Command="{Binding EditCustomDatabase1Command}" />
                    <NativeMenuItem Header="Edit Custom Database 2" Command="{Binding EditCustomDatabase2Command}" />
                    <NativeMenuItem Header="Edit Custom Database 3" Command="{Binding EditCustomDatabase3Command}" />
                    <NativeMenuItem Header="Edit Custom Database 4" Command="{Binding EditCustomDatabase4Command}" />
                    <NativeMenuItemSeparator />
                    <NativeMenuItem Header="Select Custom Database 2" Command="{Binding SelectCustomDatabase2Command}" />
                    <NativeMenuItem Header="Select Custom Database 3" Command="{Binding SelectCustomDatabase3Command}" />
                    <NativeMenuItem Header="Select Custom Database 4" Command="{Binding SelectCustomDatabase4Command}" />
                    <NativeMenuItemSeparator />
                    <NativeMenuItem Header="Edit BFB Database" Command="{Binding EditBfbDatabaseCommand}" />
                    <NativeMenuItem Header="Select BFB Database" Command="{Binding SelectBfbDatabaseCommand}" />
                </NativeMenu>
            </NativeMenuItem>
            <NativeMenuItem Header="Tools">
                <NativeMenu>
                    <NativeMenuItem Header="Create Program" Command="{Binding CreateProgramCommand}" />
                    <NativeMenuItem Header="Create Carrier Sweep" Command="{Binding CreateCarrierSweepCommand}" />
                    <NativeMenuItem Header="Create Spectrum Sweep" Command="{Binding CreateSpectrumSweepCommand}" />
                    <NativeMenuItemSeparator />
                    <NativeMenuItem Header="CS Calculator" Command="{Binding OpenCsCalculatorCommand}" />
                    <NativeMenuItemSeparator />
                    <NativeMenuItem Header="Update Presets" Command="{Binding UpdatePresetsCommand}" />
                </NativeMenu>
            </NativeMenuItem>
            <NativeMenuItem Header="Settings">
                <NativeMenu>
                    <NativeMenuItem Header="Restore Settings Defaults" Command="{Binding RestoreDefaultsCommand}" />
                    <NativeMenuItem Header="Restore BFB Defaults" Command="{Binding RestoreBfbDefaultsCommand}" />
                    <NativeMenuItemSeparator />
                    <NativeMenuItem Header="Toggle Advanced Features" Command="{Binding ToggleAdvancedFeaturesCommand}" />
                    <NativeMenuItem Header="User's Guide Mode" Command="{Binding ToggleUsersGuideModeCommand}" />
                </NativeMenu>
            </NativeMenuItem>
            <NativeMenuItem Header="Help">
                <NativeMenu>
                    <NativeMenuItem Header="User's Guide" Command="{Binding OpenUsersGuideCommand}" />
                    <NativeMenuItem Header="About Spooky" Command="{Binding ShowAboutCommand}" />
                </NativeMenu>
            </NativeMenuItem>
        </NativeMenu>
    </NativeMenu.Menu>

    <Panel>
        <!-- Loading splash (visible until DataContext is set) -->
        <Border Name="LoadingSplash" Background="#1A1A2E" IsVisible="True"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <TextBlock Text="FreqGen" FontSize="48" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Loading..." FontSize="16"
                           Foreground="#80FFFFFF" HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Width="300" Height="8"/>
            </StackPanel>
        </Border>

    <DockPanel>
        <!-- Menu Bar (visible on Windows/Linux, macOS uses NativeMenu above) -->
        <Menu DockPanel.Dock="Top" IsVisible="{OnPlatform False, Windows=True, Linux=True}">
            <MenuItem Header="_File">
                <MenuItem Header="_Save" Command="{Binding SaveCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Command="{Binding ExitApplicationCommand}" />
            </MenuItem>
            <MenuItem Header="_System">
                <MenuItem Header="_Rescan Devices" Command="{Binding RescanDevicesCommand}" />
                <MenuItem Header="_Identify Generators" Command="{Binding IdentifyGeneratorsCommand}" />
                <Separator />
                <MenuItem Header="Refresh _Database" Command="{Binding RefreshDatabaseCommand}" />
                <MenuItem Header="Refresh _Waveforms" Command="{Binding RefreshWaveformsCommand}" />
                <MenuItem Header="_Update Presets" Command="{Binding UpdatePresetsCommand}" />
                <Separator />
                <MenuItem Header="Restore _Defaults" Command="{Binding RestoreDefaultsCommand}" />
                <MenuItem Header="_About" Command="{Binding ShowAboutCommand}" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="GX Screen _On" Command="{Binding GxScreenOnCommand}" />
                <MenuItem Header="GX Screen O_ff" Command="{Binding GxScreenOffCommand}" />
                <Separator />
                <MenuItem Header="_Save Settings" Command="{Binding SaveSettingsCommand}" />
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="8,4"
                Height="33">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             IsVisible="{Binding IsDiscoveringGenerators}"
                             Width="100" Height="12"
                             VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusBarText, FallbackValue='Loading...'}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Generator Panels -->
        <ItemsControl DockPanel.Dock="Bottom"
                      ItemsSource="{Binding Generators}"
                      Margin="0,4,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" Spacing="2" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <controls:GeneratorPanel DataContext="{Binding}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Main Tab Control -->
        <TabControl>
            <TabItem Header="Presets">
                <tabs:PresetsTab DataContext="{Binding Presets}" />
            </TabItem>
            <TabItem Header="Programs">
                <tabs:DatabaseTab DataContext="{Binding Database}" />
            </TabItem>
            <TabItem Header="Settings">
                <tabs:SettingsTab DataContext="{Binding Settings}" />
            </TabItem>
            <TabItem Header="Control">
                <tabs:ControlTab DataContext="{Binding Control}" />
            </TabItem>
            <TabItem Header="System">
                <tabs:SystemTab DataContext="{Binding System}" />
            </TabItem>
            <TabItem Header="Internet">
                <TextBlock Text="Internet tab - placeholder"
                           Margin="16"
                           VerticalAlignment="Top" />
            </TabItem>
            <TabItem Header="Errors">
                <tabs:GeneratorErrorsTab DataContext="{Binding Errors}" />
            </TabItem>
        </TabControl>
    </DockPanel>
    </Panel>
</Window>
